rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true;
    }

    function isAlive() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.status == 'alive';
    }

    function ownsProfile(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Tournaments: admins write, anyone signed in reads
    match /tournaments/{tournamentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Profiles: owner creates/updates their own setup fields, admins can do anything
    match /profiles/{uid} {
      allow read: if isSignedIn();
      allow create: if ownsProfile(uid) || isAdmin();
      allow update: if ownsProfile(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['isAdmin', 'status', 'stats.matchesPlayed']);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Matches: alive players create; participants update only their safety flag; admins update all
    match /matches/{matchId} {
      allow read: if isSignedIn();

      allow create: if isAlive() &&
        request.resource.data.status == 'scheduled' &&
        request.resource.data.participants.challengerId == request.auth.uid;

      // Participant can flip their own safety ready flag and nothing else
      allow update: if isSignedIn() && (
        (resource.data.participants.challengerId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['safety']) &&
          request.resource.data.safety.diff(resource.data.safety).affectedKeys().hasOnly(['challengerReady']) &&
          request.resource.data.safety.challengerReady == true)
        ||
        (resource.data.participants.defenderId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['safety']) &&
          request.resource.data.safety.diff(resource.data.safety).affectedKeys().hasOnly(['defenderReady']) &&
          request.resource.data.safety.defenderReady == true)
      );

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
